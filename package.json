{
  "name": "promptotype",
  "version": "0.3.2",
  "description": "Browser overlay that lets you annotate UI elements and send structured feedback to AI coding agents",
  "main": "dist/promptotype.iife.js",
  "bin": {
    "promptotype": "dist/cli.mjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:cli": "node scripts/build-cli.mjs",
    "build:all": "npm run build && npm run build:cli",
    "preview": "vite preview",
    "cli": "tsx cli/index.ts",
    "build:ext": "vite build && cp dist/promptotype.iife.js extension/overlay.js",
    "test:app": "tsx test/mock-app/serve.ts",
    "test:app:nextjs": "tsx test/mock-app/serve.ts --mode nextjs",
    "test:proxy": "tsx cli/index.ts http://localhost:3000",
    "postinstall": "node npm/postinstall.js",
    "prepublishOnly": "npm run build:all"
  },
  "files": [
    "dist/cli.mjs",
    "dist/promptotype.iife.js",
    "cli/promptotype.md",
    "npm/postinstall.js"
  ],
  "keywords": [
    "design",
    "annotation",
    "ai",
    "cli",
    "browser",
    "overlay",
    "promptotype"
  ],
  "author": "Nikos Kollaros",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niforiskollaros/promptotype.git"
  },
  "homepage": "https://github.com/niforiskollaros/promptotype",
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.27.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "update-notifier": "^7.3.1",
    "vite": "^8.0.3",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  }
}
